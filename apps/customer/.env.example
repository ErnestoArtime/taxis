# Variables de entorno para la plataforma de taxis
# Copia este archivo como .env y completa los valores

# URL de tu proyecto Supabase (local o remoto)
SUPABASE_URL=http://localhost:54321

# Anon key de Supabase (publica, segura para apps Ionic)
SUPABASE_ANON_KEY=your-anon-key-here

# Slug del tenant por defecto
TENANT_SLUG=habana-taxi
