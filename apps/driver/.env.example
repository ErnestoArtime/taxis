# Variables de entorno para Driver App
# Copia este archivo como .env y completa los valores

# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key-here

# ─── Tenant ─────────────────────────────────────────────────────────────────
TENANT_SLUG=habana-taxi

# ─── Mapas ──────────────────────────────────────────────────────────────────
MAP_PROVIDER=leaflet
MAP_API_KEY=

# ─── Push ───────────────────────────────────────────────────────────────────
PUSH_PROVIDER=fcm
FCM_SERVER_KEY=