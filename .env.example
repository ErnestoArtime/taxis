# =============================================================================
# Taxi Commerce Platform — Variables de Entorno
# =============================================================================
# Copia este archivo como .env y completa los valores según tu entorno.
# Nunca subas .env a git.

# ─── Supabase ───────────────────────────────────────────────────────────────
# URL del proyecto Supabase (local: http://localhost:54321)
SUPABASE_URL=http://localhost:54321
# Anon key pública (segura para apps Ionic/PWA)
SUPABASE_ANON_KEY=your-anon-key-here
# Service role key (SOLO para backend/Edge Functions, NUNCA en frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Tenant por defecto ─────────────────────────────────────────────────────
# Slug del tenant activo (se resuelve en el login)
TENANT_SLUG=habana-taxi

# ─── Mapas ──────────────────────────────────────────────────────────────────
# Proveedor de mapas (leaflet, mapbox, google)
MAP_PROVIDER=leaflet
# API key si el proveedor la requiere (Mapbox, Google)
MAP_API_KEY=

# ─── Notificaciones ─────────────────────────────────────────────────────────
# Proveedor de push (fcm, apns)
PUSH_PROVIDER=fcm
# Credenciales FCM
FCM_SERVER_KEY=

# ─── WhatsApp ───────────────────────────────────────────────────────────────
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# ─── Entorno ────────────────────────────────────────────────────────────────
NODE_ENV=development
# Nivel de log: debug, info, warn, error
LOG_LEVEL=info
